{
    "compilerOptions": {
        "strict": true,
        "ignoreDeprecations": "6.0",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "strictNullChecks": true,
        "target": "ES2020", 
        "moduleResolution": "bundler", 
        "module": "ESNext", 
        "declaration": true,
        "declarationMap": true, 
        "sourceMap": true, 
        "isolatedModules": true,
        "skipLibCheck": true, 
        "types": ["node"],
        "outDir": "blBot" 
      
    },
    "include": ["src"],
    "exclude": [
        "node_modules",
        "blBot"
    ] 
}